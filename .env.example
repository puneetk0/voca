# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── App ──
# Local dev: http://localhost:3000. Production (Vercel): https://vocaforms.tech
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated admin allowlist. In production, unset = deny all.
ALLOWED_ADMIN_EMAILS=you@example.com

# ── AI (LLM: conversation + form generation) ──
# Runs Groq-first, then Cerebras. At least ONE of GROQ_KEY / CEREBRAS_API_KEY
# is required for forms to work. (GEMINI_KEY is an optional dormant last resort.)
GROQ_KEY=your_groq_key                 # console.groq.com — free tier
GROQ_KEY_2=optional_second_groq_key    # rate-limit rotation
GROQ_KEY_3=optional_third_groq_key
CEREBRAS_API_KEY=your_cerebras_key     # cloud.cerebras.ai — free 1M tokens/day, fast fallback
# GEMINI_KEY=optional_dormant_fallback

# ── Voice ──
# Sarvam powers BOTH speech-to-text (Saarika, Hinglish/Indian-name native) and TTS.
# STT: Sarvam Saarika → Groq Whisper.
# TTS: Sarvam bulbul:v3 → Groq Orpheus (English) → browser speech → captions mode.
SARVAM_API_KEY=your_sarvam_key
# Optional: pick any bulbul:v3 voice (priya, shreya, tanya, neha, kavya, aditya, ...)
# Full list: https://docs.sarvam.ai/api-reference-docs/getting-started/models/bulbul
SARVAM_SPEAKER=priya
# Optional: Groq Orpheus fallback voice (tara, leah, jess, leo, dan, mia, zac, zoe).
# NOTE: Orpheus needs one-time terms acceptance in the Groq console:
# https://console.groq.com/playground?model=canopylabs%2Forpheus-v1-english
GROQ_TTS_VOICE=tara

# ── Email notifications (optional) ──
RESEND_API_KEY=optional_resend_key
# Sender address. Requires a verified domain in Resend for a custom address;
# the resend.dev default works out-of-box for testing.
EMAIL_FROM=Voca <onboarding@resend.dev>
# Reply-to shown on outgoing mail (helps deliverability). Defaults to hello@vocaforms.tech
EMAIL_REPLY_TO=hello@vocaforms.tech
# Link inside the waitlist welcome email — a Voca form asking new members a
# few onboarding questions (dogfooding). CTA is hidden while unset.
WAITLIST_FORM_URL=

# ── Analytics (optional; production only) ──
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Rate limiting (optional but recommended in production) ──
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
