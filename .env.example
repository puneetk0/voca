# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated admin allowlist. In production, unset = deny all.
ALLOWED_ADMIN_EMAILS=you@example.com

# ── AI (LLM: conversation + form generation) ──
# Runs Groq-first, then Cerebras. At least ONE of GROQ_KEY / CEREBRAS_API_KEY
# is required for forms to work. (GEMINI_KEY is an optional dormant last resort.)
GROQ_KEY=your_groq_key                 # console.groq.com — free tier
GROQ_KEY_2=optional_second_groq_key    # rate-limit rotation
GROQ_KEY_3=optional_third_groq_key
CEREBRAS_API_KEY=your_cerebras_key     # cloud.cerebras.ai — free 1M tokens/day, fast fallback
# GEMINI_KEY=optional_dormant_fallback

# ── Voice ──
# Sarvam powers BOTH speech-to-text (Saarika, Hinglish-native) and text-to-speech.
# STT: Groq Whisper → Sarvam.  TTS: Sarvam → browser speech → captions mode.
SARVAM_API_KEY=your_sarvam_key

# ── Email notifications (optional) ──
RESEND_API_KEY=optional_resend_key
# Sender address. Requires a verified domain in Resend for a custom address;
# the resend.dev default works out-of-box for testing.
EMAIL_FROM=Voca <onboarding@resend.dev>

# ── Analytics (optional; production only) ──
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Rate limiting (optional but recommended in production) ──
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
